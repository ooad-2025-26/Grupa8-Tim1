@model IEnumerable<DigitalniKlubCitalaca.Models.Korisnik>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Ime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prezime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lozinka)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProfilnaSlika)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Biografija)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LokacijaX)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LokacijaY)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uloga)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusNaloga)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Ime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prezime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lozinka)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ProfilnaSlika)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Biografija)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LokacijaX)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LokacijaY)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Uloga)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusNaloga)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.KorisnikId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.KorisnikId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.KorisnikId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
