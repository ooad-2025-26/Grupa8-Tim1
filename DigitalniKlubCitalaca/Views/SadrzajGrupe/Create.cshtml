@model DigitalniKlubCitalaca.Models.SadrzajGrupe

@{
    ViewData["Title"] = "Nova objava";
}

<section class="section">
    <div style="max-width:850px; margin:auto;">

        <h1 class="section-title">Nova objava</h1>
        <p style="color:#8a8a8a; margin-top:-10px;">
            Kreirajte story, PDF materijal ili članak – vlastiti osvrt unutar ove grupe.
        </p>

        <div class="card form-box">
            <form asp-controller="SadrzajGrupe" asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="GrupaId" />
                <input type="hidden" asp-for="Link" />

                <label asp-for="TipSadrzaja">Tip objave</label>
                <select asp-for="TipSadrzaja"
                        id="tipSadrzaja"
                        asp-items="Html.GetEnumSelectList<DigitalniKlubCitalaca.Models.TipSadrzaja>()">
                </select>

                <label asp-for="Naslov">Naslov</label>
                <input asp-for="Naslov" placeholder="Unesite naslov objave..." />
                <span asp-validation-for="Naslov" class="text-danger"></span>

                <div id="clanakBox" style="
                    margin-top:18px;
                    background:#fbfaf5;
                    border:1px solid #eee7df;
                    border-radius:24px;
                    padding:22px;">
                    <label asp-for="Opis">Članak – napišite vlastiti osvrt</label>
                    <textarea asp-for="Opis"
                              rows="9"
                              placeholder="Napišite svoj osvrt na knjigu, mišljenje, preporuku ili utisak nakon čitanja..."></textarea>
                    <span asp-validation-for="Opis" class="text-danger"></span>

                    <small style="color:#8a8a8a;">
                        Ovdje članovi mogu podijeliti vlastiti tekstualni osvrt na knjigu. Za članak nije potreban PDF.
                    </small>
                </div>

                <div id="pdfBox" style="
                    display:none;
                    margin-top:18px;
                    background:#fbfaf5;
                    border:1px solid #eee7df;
                    border-radius:24px;
                    padding:22px;">
                    <label>PDF materijal</label>
                    <input type="file" name="pdfFile" accept="application/pdf" />
                    <small style="color:#8a8a8a;">
                        Odaberite PDF materijal koji želite podijeliti u grupi.
                    </small>
                </div>

                <div id="storyBox" style="
                    display:none;
                    margin-top:20px;
                    background:#fbfaf5;
                    border:1px solid #eee7df;
                    border-radius:24px;
                    padding:22px;">
                    <label>Story objava</label>

                    <div style="
                        background:white;
                        border:1px dashed #e7ddd3;
                        border-radius:20px;
                        padding:18px;
                        margin-top:12px;">
                        <label>Odaberi sliku sa laptopa</label>
                        <input type="file" id="storyFile" accept="image/*" />
                        <small style="color:#8a8a8a;">
                            Možete odabrati sliku ili uslikati web kamerom.
                        </small>
                    </div>

                    <div style="padding:1rem 0 0; display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                        <div id="results"
                             style="
                            border:1px dashed #ddd;
                            border-radius:18px;
                            padding:20px;
                            min-height:240px;
                            background:white;">
                            Slika će se prikazati ovdje...
                        </div>

                        <div>
                            <div id="my_camera"></div>

                            <input type="button"
                                   id="takeshot"
                                   class="btn-pink"
                                   value="Uslikaj"
                                   onclick="take_snapshot()"
                                   style="margin-top:15px;" />
                        </div>
                    </div>
                </div>

                <div style="display:flex; gap:12px; margin-top:28px;">
                    <button type="submit" class="btn-pink">
                        Objavi
                    </button>

                    <a class="btn-dark"
                           asp-controller="CitalackaGrupa"
                           asp-action="Details"
                           asp-route-id="@Model.GrupaId">
                        Nazad u grupu
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let streamKamere = null;

        async function pokreniKameru() {
            if (streamKamere) return;

            try {
                streamKamere = await navigator.mediaDevices.getUserMedia({ video: true });

                const video = document.createElement("video");
                video.id = "videoKamera";
                video.autoplay = true;
                video.playsInline = true;
                video.style.width = "320px";
                video.style.height = "240px";
                video.style.borderRadius = "18px";
                video.style.objectFit = "cover";

                document.getElementById("my_camera").innerHTML = "";
                document.getElementById("my_camera").appendChild(video);

                video.srcObject = streamKamere;
            }
            catch (err) {
                alert("Kamera se ne može pokrenuti. Provjeri da li si dozvolila pristup kameri.");
                console.log(err);
            }
        }

        function take_snapshot() {
            const video = document.getElementById("videoKamera");

            if (!video) {
                alert("Kamera još nije pokrenuta.");
                pokreniKameru();
                return;
            }

            const canvas = document.createElement("canvas");
            canvas.width = video.videoWidth || 320;
            canvas.height = video.videoHeight || 240;

            const context = canvas.getContext("2d");
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            const data_uri = canvas.toDataURL("image/jpeg", 0.85);

            document.getElementById("results").innerHTML =
                '<img src="' + data_uri + '" style="max-width:100%; border-radius:18px;" />';

            document.getElementById("Link").value = data_uri;
        }

        document.addEventListener("DOMContentLoaded", function () {

            const storyFile = document.getElementById("storyFile");

            if (storyFile) {
                storyFile.addEventListener("change", function () {
                    const file = this.files[0];

                    if (!file) return;

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const base64Slika = e.target.result;

                        document.getElementById("results").innerHTML =
                            '<img src="' + base64Slika + '" style="max-width:100%; border-radius:18px;" />';

                        document.getElementById("Link").value = base64Slika;
                    };

                    reader.readAsDataURL(file);
                });
            }

            document.getElementById("tipSadrzaja")
                .addEventListener("change", prikaziPolja);

            prikaziPolja();
        });

        function prikaziPolja() {
            var tip = document.getElementById("tipSadrzaja").value;

            document.getElementById("clanakBox").style.display = "none";
            document.getElementById("pdfBox").style.display = "none";
            document.getElementById("storyBox").style.display = "none";

            if (tip === "0") {
                document.getElementById("pdfBox").style.display = "block";
            }
            else if (tip === "1") {
                document.getElementById("clanakBox").style.display = "block";
            }
            else if (tip === "2") {
                document.getElementById("storyBox").style.display = "block";
                pokreniKameru();
            }
        }
    </script>
}