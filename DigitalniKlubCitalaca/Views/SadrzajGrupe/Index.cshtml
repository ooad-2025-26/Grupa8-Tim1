@model IEnumerable<DigitalniKlubCitalaca.Models.SadrzajGrupe>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Autor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CitalackaGrupa)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumObjave)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Naslov)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Opis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Link)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipSadrzaja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusSadrzaja)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Autor.KorisnikId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CitalackaGrupa.GrupaId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumObjave)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Naslov)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Opis)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Link)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipSadrzaja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusSadrzaja)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.SadrzajId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.SadrzajId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.SadrzajId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
