@model IEnumerable<DigitalniKlubCitalaca.Models.SadrzajGrupe>

@{
    ViewData["Title"] = "Objave";
}

<section class="section">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
        <div>
            <h1 class="section-title">Objave u grupama</h1>
            <p style="color:#8a8a8a; margin-top:-10px;">
                Pregled članaka, fajlova i sadržaja objavljenih u čitalačkim grupama.
            </p>
        </div>

        <a class="btn-pink" asp-action="Create">
            + Nova objava
        </a>
    </div>

    <div class="grid-3">
        @foreach (var item in Model)
        {
            <div class="card">

                <div style="
                    height:150px;
                    border-radius:22px;
                    background:linear-gradient(135deg,#fff0f3,#f2ebe4);
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:55px;
                    margin-bottom:20px;">
                    📝
                </div>

                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:14px;">
                    <span class="badge">
                        @item.TipSadrzaja
                    </span>

                    <span class="badge">
                        @item.StatusSadrzaja
                    </span>
                </div>

                <h2 style="font-family:Georgia,serif; margin:0 0 8px;">
                    @(string.IsNullOrWhiteSpace(item.Naslov)
                        ? "Objava bez naslova"
                        : item.Naslov)
                </h2>

                <p style="color:#8a8a8a; font-size:14px;">
                    Autor: @(item.Autor?.Email ?? item.Autor?.UserName ?? "Nepoznat korisnik")
                </p>

                <p style="color:#8a8a8a; font-size:14px;">
                    Grupa ID: @item.CitalackaGrupa?.GrupaId
                </p>

                <p style="color:#8a8a8a; font-size:14px;">
                    📅 @item.DatumObjave.ToString("dd.MM.yyyy")
                </p>

                <p style="color:#555; min-height:70px;">
                    @(string.IsNullOrWhiteSpace(item.Opis)
                        ? "Opis objave nije dodan."
                        : item.Opis.Length > 120
                            ? item.Opis.Substring(0, 120) + "..."
                            : item.Opis)
                </p>

                @if (!string.IsNullOrWhiteSpace(item.Link))
                {
                    <p>
                        <a href="@item.Link"
                           target="_blank"
                           style="color:#e85d75; text-decoration:none; font-weight:600;">
                            Otvori link
                        </a>
                    </p>
                }

                <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:20px;">
                    <a class="btn-pink"
                       asp-action="Details"
                       asp-route-id="@item.SadrzajId">
                        Detalji
                    </a>

                    <a class="btn-dark"
                       asp-action="Edit"
                       asp-route-id="@item.SadrzajId">
                        Uredi
                    </a>

                    <a class="btn-dark"
                       asp-action="Delete"
                       asp-route-id="@item.SadrzajId">
                        Obriši
                    </a>
                </div>

            </div>
        }
    </div>

</section>