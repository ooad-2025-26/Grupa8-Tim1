@model IEnumerable<DigitalniKlubCitalaca.Models.SadrzajGrupe>

@{
    ViewData["Title"] = "Objave";
}

<section class="section">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">

        <div>
            <h1 class="section-title">Objave u grupama</h1>

            <p style="color:#8a8a8a; margin-top:-10px;">
                Pregled svih objavljenih sadržaja.
            </p>
        </div>

        <a class="btn-pink" asp-action="Create">
            + Nova objava
        </a>

    </div>

    <div class="grid-3">

        @foreach (var item in Model)
        {
            <div class="card">

                <div style="
                    height:140px;
                    border-radius:20px;
                    background:#fff0f3;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:50px;
                    margin-bottom:18px;">
                    📝
                </div>

                <div style="display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap;">
                    <span class="badge">@item.TipSadrzaja</span>
                    <span class="badge">@item.StatusSadrzaja</span>
                </div>

                <h3 style="margin-bottom:10px;">
                    @item.Naslov
                </h3>

                <p style="color:#8a8a8a; font-size:14px;">
                    📅 @item.DatumObjave.ToString("dd.MM.yyyy")
                </p>

                <p style="color:#555; min-height:70px;">
                    @(string.IsNullOrWhiteSpace(item.Opis)
                        ? "Nema opisa."
                        : item.Opis)
                </p>

                <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:20px;">

                    <a class="btn-pink"
                       asp-action="Details"
                       asp-route-id="@item.SadrzajId">
                        Detalji
                    </a>

                    <a class="btn-dark"
                       asp-action="Edit"
                       asp-route-id="@item.SadrzajId">
                        Uredi
                    </a>

                    <a class="btn-dark"
                       asp-action="Delete"
                       asp-route-id="@item.SadrzajId">
                        Obriši
                    </a>

                </div>

            </div>
        }

    </div>

</section>