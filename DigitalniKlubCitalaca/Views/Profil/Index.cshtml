@model IEnumerable<DigitalniKlubCitalaca.Models.Profil>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OpisProfila)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lokacija)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Korisnik.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OpisProfila)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lokacija)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProfilId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ProfilId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ProfilId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
