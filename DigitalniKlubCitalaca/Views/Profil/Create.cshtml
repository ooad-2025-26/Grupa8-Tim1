@model DigitalniKlubCitalaca.Models.Profil

@{
    ViewData["Title"] = "Kreiraj profil";
}

<section class="section">
    <div style="margin-bottom:30px;">
        <h1 class="section-title">Kreiraj profil</h1>
        <p style="color:#8a8a8a; margin-top:-10px;">
            Dodaj opis profila i lokaciju korisnika.
        </p>
    </div>

    <div class="card form-box">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label asp-for="OpisProfila">Opis profila</label>
            <textarea asp-for="OpisProfila" rows="5" placeholder="Napiši nešto o sebi..."></textarea>
            <span asp-validation-for="OpisProfila" class="text-danger"></span>

            <label asp-for="Lokacija">Lokacija</label>
            <input asp-for="Lokacija" placeholder="npr. Sarajevo" />
            <span asp-validation-for="Lokacija" class="text-danger"></span>

            <div style="display:flex; gap:12px; margin-top:25px;">
                <button type="submit" class="btn-pink">
                    Kreiraj profil
                </button>

                <a class="btn-dark" asp-action="Index">
                    Nazad
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}