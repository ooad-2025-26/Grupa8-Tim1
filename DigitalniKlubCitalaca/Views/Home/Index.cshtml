@using Microsoft.AspNetCore.Identity
@using DigitalniKlubCitalaca.Models
@inject UserManager<Korisnik> UserManager
@inject SignInManager<Korisnik> SignInManager

@{
    ViewData["Title"] = "Početna";
    Korisnik trenutniKorisnik = null;

    if (SignInManager.IsSignedIn(User))
    {
        trenutniKorisnik = await UserManager.GetUserAsync(User);
    }
}
@if (trenutniKorisnik != null && trenutniKorisnik.StatusNaloga == StatusNaloga.blokiran)
{
    <div class="alert alert-danger text-center p-4 mt-5" style="border-radius:20px;">
        <h2>Vaš nalog je suspendovan</h2>
        <p class="mb-0">
            Trenutno nemate pristup funkcionalnostima sistema.
            Za više informacija obratite se administratoru.
        </p>
    </div>
}else
{
<section id="pocetna"
         style="
         min-height:85vh;
         display:flex;
         align-items:center;
         justify-content:center;
         text-align:center;
         padding:40px;">

        

    <div>
        <h1 style="
            font-size:80px;
            font-family:Georgia,serif;
            line-height:1.1;
            margin-bottom:20px;">

            Digitalni klub <br />

            <span style="
                color:#e85d75;
                font-style:italic;
                font-weight:300;">
                čitalaca
            </span>
        </h1>

        <p style="
            max-width:650px;
            margin:auto;
            color:#777;
            font-size:20px;
            line-height:1.8;">

            Dobrodošli u vaš novi omiljeni kutak za čitanje.
            Povežite se sa ljubiteljima knjiga,
            dijelite utiske i otkrijte nove svjetove.
        </p>

        <div style="margin-top:35px;">
            <a asp-controller="Home"
               asp-action="About"
               class="btn-pink"
               style="padding:16px 32px; font-size:18px;">
                Započni putovanje →
            </a>
        </div>
    </div>

</section>
}