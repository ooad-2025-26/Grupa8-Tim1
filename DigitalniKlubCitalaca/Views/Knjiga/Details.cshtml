@model DigitalniKlubCitalaca.Models.Knjiga
@using DigitalniKlubCitalaca.Models

@{
    ViewData["Title"] = "Detalji knjige";
    var komentari = ViewBag.Komentari as List<Komentar>;
}

<section class="section">
    <div style="max-width:980px; margin:auto;">

        <a asp-action="Index" style="color:#777; text-decoration:none; font-weight:500;">
            ← Nazad
        </a>

        <div class="card" style="margin-top:22px; padding:0; overflow:hidden; border-radius:30px;">
            <div style="display:grid; grid-template-columns:330px 1fr; gap:0;">

                <div style="
                    background:url('https://images.unsplash.com/photo-1512820790803-83ca734da794?q=80&w=1200&auto=format&fit=crop');
                    background-size:cover;
                    background-position:center;
                    min-height:420px;">
                </div>

                <div style="padding:38px;">
                    <span class="badge">@Model.Zanr</span>

                    <h1 style="font-family:Georgia,serif; margin:18px 0 10px; font-size:46px; line-height:1.1;">
                        @Model.Naziv
                    </h1>

                    <p style="color:#8a8a8a; font-size:18px; margin-bottom:25px;">
                        Autor: @Model.Autor
                    </p>

                    <div style="background:#fbfaf5; border:1px solid #eee7df; border-radius:22px; padding:22px; line-height:1.8; color:#444;">
                        @(string.IsNullOrWhiteSpace(Model.Opis) ? "Opis knjige nije dodan." : Model.Opis)
                    </div>

                    <div style="display:flex; gap:12px; margin-top:24px; flex-wrap:wrap;">
                        <span class="badge">📄 @Model.BrojStranica stranica</span>
                        <span class="badge">💬 Diskusija</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card" style="margin-top:30px; padding:30px; border-radius:30px;">
            <div style="margin-bottom:25px;">
                <h2 style="font-family:Georgia,serif; margin:0;">Komentari</h2>
                <p style="color:#8a8a8a; margin:6px 0 0;">
                    Diskusija korisnika o knjizi.
                </p>
            </div>

            @if (komentari != null && komentari.Any())
            {
                foreach (var komentar in komentari)
                {
                    <div style="display:flex; gap:14px; align-items:flex-start; border-bottom:1px solid #eee7df; padding-bottom:18px; margin-bottom:18px;">
                        <div style="width:46px; height:46px; border-radius:50%; background:#fff0f3; display:flex; align-items:center; justify-content:center; font-size:20px;">
                            👤
                        </div>

                        <div style="flex:1;">
                            <strong>
                                @(komentar.Autor?.Email ?? komentar.Autor?.UserName ?? "Korisnik")
                            </strong>

                            <p style="color:#8a8a8a; font-size:13px; margin:4px 0;">
                                @komentar.DatumKomentara.ToString("dd.MM.yyyy HH:mm")
                            </p>

                            <p style="margin-top:10px; line-height:1.6;">
                                @komentar.Tekst
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="color:#8a8a8a;">
                    Još nema komentara za prikaz.
                </p>
            }

            @if (TempData["KomentarPoruka"] != null)
{
    <div style="background:#e8f7ee; color:#267344; padding:12px 16px; border-radius:16px; margin-bottom:15px;">
        @TempData["KomentarPoruka"]
    </div>
}

@if (TempData["KomentarGreska"] != null)
{
    <div style="background:#fff0f3; color:#e63946; padding:12px 16px; border-radius:16px; margin-bottom:15px;">
        @TempData["KomentarGreska"]
    </div>
}

<form asp-action="DodajKomentar" method="post" style="display:flex; gap:12px; margin-top:22px;">
    @Html.AntiForgeryToken()

    <input type="hidden" name="knjigaId" value="@Model.KnjigaId" />

    <input name="tekst"
           placeholder="Dodaj komentar..."
           style="flex:1; padding:14px 18px; border:1px solid #eee7df; border-radius:20px; outline:none;" />

    <button type="submit" class="btn-pink">
        Pošalji
    </button>
</form>
        </div>

    </div>
</section>