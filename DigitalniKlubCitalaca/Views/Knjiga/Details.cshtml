@model DigitalniKlubCitalaca.Models.Knjiga

@{
    ViewData["Title"] = "Detalji knjige";
    var jeAdministrator = ViewBag.JeAdministrator == true;
}

<section class="section">
    <div style="max-width:1050px; margin:auto;">

        <a asp-action="Index" style="color:#777; text-decoration:none;">
            ← Nazad na biblioteku
        </a>

        <div class="card" style="
            margin-top:25px;
            padding:36px;
            border-radius:34px;
            background:linear-gradient(135deg,#fff,#fbfaf5);">

            <div style="display:grid; grid-template-columns:170px 1fr; gap:30px; align-items:start;">

                <div style="
                    width:170px;
                    height:230px;
                    border-radius:26px;
                    background:linear-gradient(145deg,#fff0f3,#f2ebe4);
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:72px;
                    box-shadow:0 16px 35px rgba(0,0,0,0.08);">
                    📖
                </div>

                <div>
                    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px;">
                        <span class="badge">@Model.Zanr</span>
                        <span class="badge">📄 @Model.BrojStranica stranica</span>
                        <span class="badge">Digitalna biblioteka</span>
                    </div>

                    <h1 style="font-family:Georgia,serif; font-size:42px; margin:0 0 8px;">
                        @Model.Naziv
                    </h1>

                    <p style="color:#8a8a8a; font-size:17px; margin-bottom:24px;">
                        Autor: @Model.Autor
                    </p>

                    <div style="
                        background:white;
                        border:1px solid #eee7df;
                        border-radius:24px;
                        padding:24px;
                        margin-bottom:24px;">
                        <h3 style="font-family:Georgia,serif; margin-top:0;">
                            Kratki opis knjige
                        </h3>

                        <p style="line-height:1.8; color:#444; margin-bottom:0;">
                            @(string.IsNullOrWhiteSpace(Model.Opis)
                                ? "Opis knjige nije dodan."
                                : Model.Opis)
                        </p>
                    </div>

                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <a class="btn-pink"
                               asp-action="Citaj"
                               asp-route-id="@Model.KnjigaId">
                            Čitaj knjigu
                        </a>

                        @if (jeAdministrator)
                        {
                            <a class="btn-dark" asp-action="Edit" asp-route-id="@Model.KnjigaId">
                                Uredi
                            </a>

                            <a class="btn-dark" asp-action="Delete" asp-route-id="@Model.KnjigaId">
                                Obriši
                            </a>
                        }
                    </div>

                    <p style="color:#8a8a8a; margin-top:16px; font-size:14px;">
                        Za čitanje PDF knjige potrebno je biti prijavljen na sistem.
                    </p>
                </div>
            </div>
        </div>

    </div>
</section>