@model IEnumerable<DigitalniKlubCitalaca.Models.Knjiga>

@{
    ViewData["Title"] = "Biblioteka";
    var zanrovi = ViewBag.Zanrovi as List<string> ?? new List<string>();
    var odabraniZanr = ViewBag.OdabraniZanr as string;
    var jeAdministrator = ViewBag.JeAdministrator == true;
}

<section class="section">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:20px; margin-bottom:30px;">
        <div>
            <h1 class="section-title">Pronađi svoj žanr</h1>
            <p style="color:#8a8a8a; margin-top:-10px; max-width:700px;">
                Digitalna biblioteka dostupna svim ljubiteljima knjiga. Istražite različite žanrove,
                pročitajte opis knjige i započnite svoje novo čitalačko putovanje.
            </p>
        </div>

        @if (jeAdministrator)
        {
            <a class="btn-pink" asp-action="Create">
                + Dodaj knjigu
            </a>
        }
    </div>

    <div class="card" style="padding:24px; border-radius:28px; margin-bottom:30px;">
        <h3 style="font-family:Georgia,serif; margin-top:0;">Žanrovi</h3>

        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a asp-action="Index"
                   class="badge"
                   style="text-decoration:none; @(string.IsNullOrWhiteSpace(odabraniZanr) ? "background:#e85d75;color:white;" : "")">
                Svi žanrovi
            </a>

            @foreach (var zanr in zanrovi)
            {
                <a asp-action="Index"
                       asp-route-zanr="@zanr"
                       class="badge"
                       style="text-decoration:none; @(odabraniZanr == zanr ? "background:#e85d75;color:white;" : "")">
                    @zanr
                </a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="grid-3">
            @foreach (var item in Model)
            {
                <div class="card" style="overflow:hidden; border-radius:30px;">
                    <div style="
                        height:190px;
                        background:linear-gradient(135deg,#fff0f3,#f2ebe4);
                        border-radius:24px;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        font-size:72px;
                        margin-bottom:20px;">
                        📖
                    </div>

                    <span class="badge">@item.Zanr</span>

                    <h2 style="font-family:Georgia,serif; margin:16px 0 6px;">
                        @item.Naziv
                    </h2>

                    <p style="color:#8a8a8a; margin-bottom:14px;">
                        Autor: @item.Autor
                    </p>

                    <p style="color:#555; min-height:78px; line-height:1.6;">
                        @(string.IsNullOrWhiteSpace(item.Opis)
                            ? "Opis knjige nije dodan."
                            : item.Opis.Length > 135
                                ? item.Opis.Substring(0, 135) + "..."
                                : item.Opis)
                    </p>

                    <div style="display:flex; gap:8px; flex-wrap:wrap; margin:18px 0;">
                        <span class="badge">📄 @item.BrojStranica stranica</span>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:20px;">
                        <a class="btn-pink" asp-action="Details" asp-route-id="@item.KnjigaId">
                            Pročitaj više
                        </a>

                        @if (jeAdministrator)
                        {
                            <a class="btn-dark" asp-action="Edit" asp-route-id="@item.KnjigaId">
                                Uredi
                            </a>

                            <a class="btn-dark" asp-action="Delete" asp-route-id="@item.KnjigaId">
                                Obriši
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card" style="padding:35px; text-align:center; color:#8a8a8a; border-radius:28px;">
            <div style="font-size:48px; margin-bottom:12px;">📚</div>
            <h3 style="font-family:Georgia,serif; color:#333;">Nema knjiga za odabrani žanr</h3>
            <p>Dodajte knjige u biblioteku ili odaberite drugi žanr.</p>
        </div>
    }
</section>