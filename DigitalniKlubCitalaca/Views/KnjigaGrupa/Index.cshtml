@model IEnumerable<DigitalniKlubCitalaca.Models.KnjigaGrupa>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Knjiga)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CitalackaGrupa)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Knjiga.KnjigaId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CitalackaGrupa.GrupaId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.KnjigaGrupaId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.KnjigaGrupaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.KnjigaGrupaId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
