@model DigitalniKlubCitalaca.Models.CitalackaGrupa

@{
    ViewData["Title"] = "Detalji grupe";
}

<section class="section">

    <div style="max-width:900px; margin:auto;">

        <a asp-action="Index"
           style="color:#777; text-decoration:none;">
            ← Nazad
        </a>

        <div class="card"
             style="margin-top:25px; padding:35px;">

            <div style="
                display:flex;
                gap:20px;
                align-items:center;
                margin-bottom:25px;">

                <div style="
                    width:90px;
                    height:90px;
                    border-radius:24px;
                    background:#fff0f3;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:42px;">
                    📚
                </div>

                <div>

                    <div style="
                        display:flex;
                        gap:8px;
                        flex-wrap:wrap;
                        margin-bottom:10px;">

                        <span class="badge">
                            @Model.Zanr
                        </span>

                        <span class="badge">
                            @Model.TipGrupe
                        </span>

                    </div>

                    <h1 style="
                        font-family:Georgia,serif;
                        margin:0;">
                        @Model.Naziv
                    </h1>

                    <p style="
                        color:#8a8a8a;
                        margin-top:8px;">
                        📍 @Model.Grad, @Model.Regija
                    </p>

                </div>

            </div>

            <div style="
                background:#fbfaf5;
                border:1px solid #eee7df;
                border-radius:22px;
                padding:25px;
                margin-bottom:25px;">

                <h3>Opis grupe</h3>

                <p style="
                    line-height:1.8;
                    color:#444;">
                    @Model.Opis
                </p>

            </div>

            <div style="
                display:grid;
                grid-template-columns:1fr 1fr;
                gap:18px;">

                <div class="card">

                    <h4>Broj članova</h4>

                    <p>
                        👥 Maksimalno:
                        @Model.MaksimalanBrojClanova
                    </p>

                </div>

                <div class="card">

                    <h4>Kreirana</h4>

                    <p>
                        📅 @Model.DatumKreiranja.ToString("dd.MM.yyyy")
                    </p>

                </div>

            </div>

            <div style="
                display:flex;
                gap:12px;
                margin-top:30px;">

                <a class="btn-pink"
                   asp-action="Edit"
                   asp-route-id="@Model.GrupaId">
                    Uredi grupu
                </a>

                <a class="btn-dark"
                   asp-action="Index">
                    Nazad
                </a>

            </div>

        </div>

    </div>

</section>