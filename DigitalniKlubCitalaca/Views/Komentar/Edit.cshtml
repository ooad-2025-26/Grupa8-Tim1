@model DigitalniKlubCitalaca.Models.Komentar

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Komentar</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="KomentarId" />
            <div class="form-group">
                <label asp-for="SadrzajId" class="control-label"></label>
                <select asp-for="SadrzajId" class="form-control" asp-items="ViewBag.SadrzajId"></select>
                <span asp-validation-for="SadrzajId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AutorId" class="control-label"></label>
                <select asp-for="AutorId" class="form-control" asp-items="ViewBag.AutorId"></select>
                <span asp-validation-for="AutorId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Tekst" class="control-label"></label>
                <input asp-for="Tekst" class="form-control" />
                <span asp-validation-for="Tekst" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DatumKomentara" class="control-label"></label>
                <input asp-for="DatumKomentara" class="form-control" />
                <span asp-validation-for="DatumKomentara" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StatusKomentara" class="control-label"></label>
                <select asp-for="StatusKomentara" class="form-control"></select>
                <span asp-validation-for="StatusKomentara" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
