@model DigitalniKlubCitalaca.Models.Komentar

@{
    ViewData["Title"] = "Obriši komentar";
}

<section class="section">
    <div style="max-width:760px; margin:auto;">

        <h1 class="section-title">Obriši komentar</h1>

        <div class="card" style="padding:30px; border-radius:28px;">

            <div style="display:flex; gap:14px; align-items:flex-start;">

                <div style="
                    width:52px;
                    height:52px;
                    border-radius:50%;
                    background:#fff0f3;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    font-size:24px;">
                    ⚠️
                </div>

                <div style="flex:1;">

                    <h3 style="margin-top:0;">
                        Da li ste sigurni?
                    </h3>

                    <p style="color:#8a8a8a;">
                        Ovaj komentar će biti trajno obrisan.
                    </p>

                    <div style="
                        background:#fbfaf5;
                        border:1px solid #eee7df;
                        border-radius:18px;
                        padding:18px;
                        margin-top:20px;">

                        <strong>
                            @(Model.Autor?.Email ?? Model.Autor?.UserName ?? "Nepoznat korisnik")
                        </strong>

                        <p style="
                            color:#8a8a8a;
                            font-size:14px;
                            margin-top:6px;">
                            @Model.DatumKomentara.ToString("dd.MM.yyyy HH:mm")
                        </p>

                        <p style="margin-top:14px;">
                            @Model.Tekst
                        </p>

                    </div>

                </div>

            </div>

            <form asp-action="Delete" style="margin-top:28px;">

                <input type="hidden" asp-for="KomentarId" />

                <div style="
                    display:flex;
                    justify-content:flex-end;
                    gap:12px;">

                    <a class="btn-dark"
                       asp-action="Index">
                        Nazad
                    </a>

                    <button type="submit"
                            style="
                            background:#e63946;
                            color:white;
                            border:none;
                            border-radius:24px;
                            padding:12px 24px;">
                        Obriši komentar
                    </button>

                </div>

            </form>

        </div>

    </div>
</section>