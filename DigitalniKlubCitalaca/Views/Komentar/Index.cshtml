@model IEnumerable<DigitalniKlubCitalaca.Models.Komentar>

@{
    ViewData["Title"] = "Komentari";
}

<section class="section">
    <div style="max-width:950px; margin:auto;">

        <div style="margin-bottom:28px;">
            <h1 class="section-title">Komentari sadržaja</h1>
            <p style="color:#8a8a8a; margin-top:-10px;">
                Pregled diskusija i komentara unutar čitalačkih grupa.
            </p>
        </div>

        <div class="card" style="padding:28px; border-radius:28px;">

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
                <div>
                    <h2 style="font-family:Georgia,serif; margin:0;">Diskusija</h2>
                    <p style="color:#8a8a8a; margin:6px 0 0;">
                        Komentari korisnika na objavljeni sadržaj
                    </p>
                </div>

                <a class="btn-dark" asp-action="Create">
                    + Novi komentar
                </a>
            </div>

            <div style="display:flex; flex-direction:column; gap:18px;">
                @foreach (var item in Model)
                {
                    <div style="display:flex; gap:14px; align-items:flex-start; padding:14px 0; border-bottom:1px solid #eee7df;">

                        <div style="width:42px; height:42px; border-radius:50%; background:#fff0f3; display:flex; align-items:center; justify-content:center; font-size:20px;">
                            👤
                        </div>

                        <div style="flex:1;">
                            <div style="display:flex; justify-content:space-between; gap:12px;">
                                <div>
                                    <strong>
                                        @(item.Autor?.Email ?? item.Autor?.UserName ?? "Nepoznat korisnik")
                                    </strong>

                                    <p style="margin:4px 0 0; color:#8a8a8a; font-size:13px;">
                                        @item.DatumKomentara.ToString("dd.MM.yyyy HH:mm")
                                    </p>
                                </div>

                                <span class="badge">
                                    @item.StatusKomentara
                                </span>
                            </div>

                            <p style="margin:12px 0; color:#444;">
                                @(string.IsNullOrWhiteSpace(item.Tekst) ? "Komentar nema tekst." : item.Tekst)
                            </p>

                            <div style="display:flex; gap:12px; font-size:14px;">
                                <a asp-action="Details" asp-route-id="@item.KomentarId" style="color:#e85d75; text-decoration:none;">
                                    Detalji
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.KomentarId" style="color:#555; text-decoration:none;">
                                    Uredi
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.KomentarId" style="color:#e63946; text-decoration:none;">
                                    Obriši
                                </a>
                            </div>
                        </div>

                    </div>
                }
            </div>

            <div style="margin-top:22px; display:flex; gap:10px; align-items:center;">
                <input placeholder="Dodaj komentar..."
                       style="flex:1; padding:13px 16px; border:1px solid #eee7df; border-radius:18px;" />

                <a class="btn-pink" asp-action="Create">
                    Pošalji
                </a>
            </div>

        </div>
    </div>
</section>