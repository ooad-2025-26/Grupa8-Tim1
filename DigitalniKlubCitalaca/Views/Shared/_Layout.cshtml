@using Microsoft.AspNetCore.Identity
@using DigitalniKlubCitalaca.Models
@inject SignInManager<Korisnik> SignInManager
@inject UserManager<Korisnik> UserManager

<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DigitalniKlubCitalaca</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body style="margin:0; background:#fbfaf5; font-family:Arial, sans-serif;">

    <div style="max-width:1400px; margin:auto; padding:25px;">

        <header style="
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:40px;
        ">

            <a asp-controller="Home"
               asp-action="Index"
               style="
                    text-decoration:none;
                    font-size:32px;
                    font-weight:700;
                    color:#e85d75;
                    font-family:Georgia, serif;
               ">
                Digitalni Klub Čitalaca
            </a>

            <nav style="display:flex; gap:28px; align-items:center;">

                <a asp-controller="Home" asp-action="Index" style="text-decoration:none; color:#333;">
                    Početna
                </a>

                <a asp-controller="Knjiga" asp-action="Index" style="text-decoration:none; color:#333;">
                    Knjige
                </a>



                <a asp-controller="CitalackaGrupa" asp-action="Index" style="text-decoration:none; color:#333;">
                    Grupe
                </a>
                @if (SignInManager.IsSignedIn(User))
                {
                    var trenutniKorisnik = await UserManager.GetUserAsync(User);

                    if (trenutniKorisnik != null && trenutniKorisnik.Uloga == Uloga.administrator)
                    {
                        <a asp-controller="Admin" asp-action="Index" style="text-decoration:none; color:#333;">
                            Admin
                        </a>
                    }
                }

@if (SignInManager.IsSignedIn(User))
{
    <a asp-controller="Notifikacija"
       asp-action="Index"
       style="
       text-decoration:none;
       font-size:24px;">
        🔔
    </a>

    <a asp-controller="Profil"
       asp-action="Index"
       style="
        background:#1f1f1f;
        color:white;
        padding:12px 24px;
        border-radius:30px;
        text-decoration:none;">
        Moj profil
    </a>

    <form asp-area="Identity"
          asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
          method="post"
          style="margin:0;">
        <button type="submit"
                style="
            background:#e85d75;
            color:white;
            padding:12px 24px;
            border-radius:30px;
            border:none;
            font-weight:600;
            cursor:pointer;">
            Odjava
        </button>
    </form>
}
else
{
    <a asp-area="Identity"
       asp-page="/Account/Login"
       style="
        background:#1f1f1f;
        color:white;
        padding:12px 24px;
        border-radius:30px;
        text-decoration:none;">
        Pridruži se
    </a>
}
            </nav>

        </header>

        <main>
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>