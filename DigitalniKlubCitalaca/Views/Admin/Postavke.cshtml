@{
    ViewData["Title"] = "Postavke sistema";
}

<h1 class="mb-2">Postavke sistema</h1>
<p class="text-muted mb-4">Upravljanje osnovnim postavkama aplikacije.</p>

<div class="card shadow-sm border-0 p-4 mt-3" style="border-radius: 22px;">

    <h4 class="mb-4">Opće postavke</h4>

    <div class="form-check form-switch mb-4">
        <input class="form-check-input" type="checkbox" id="maintenance">
        <label class="form-check-label fw-semibold" for="maintenance">
            Maintenance Mode
        </label>
        <div class="text-muted small">
            Privremeno onemogući korištenje sistema.
        </div>
    </div>

    <div class="form-check form-switch mb-4">
        <input class="form-check-input" type="checkbox" id="registracija" checked>
        <label class="form-check-label fw-semibold" for="registracija">
            Dozvoli javnu registraciju
        </label>
        <div class="text-muted small">
            Novi korisnici se mogu samostalno registrovati.
        </div>
    </div>

    <div class="form-check form-switch mb-4">
        <input class="form-check-input" type="checkbox" id="komentari" checked>
        <label class="form-check-label fw-semibold" for="komentari">
            Dozvoli komentare gostiju
        </label>
        <div class="text-muted small">
            Gosti mogu ostavljati komentare na sadržaj.
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label fw-semibold">Jezik sistema</label>
        <select class="form-select">
            <option>Bosanski</option>
            <option>English</option>
        </select>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn text-white px-4" style="background-color:#e95478; border-radius:20px;">
            Sačuvaj postavke
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius:20px;">
            Nazad
        </a>
    </div>

</div>