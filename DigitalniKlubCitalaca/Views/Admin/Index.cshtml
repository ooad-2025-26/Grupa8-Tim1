@model IEnumerable<DigitalniKlubCitalaca.Models.Korisnik>

@{
    ViewData["Title"] = "Administracija sistema";
}

<h1>Administracija sistema</h1>
<h4>Upravljanje korisnicima</h4>
<ul class="nav nav-tabs">
    <li class="nav-item">
        <a class="nav-link active" asp-controller="Admin" asp-action="Index">
            Korisnici
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link" asp-controller="Admin" asp-action="Postavke">
            Postavke
        </a>
    </li>

    <li class="nav-item">
        <a class="nav-link" asp-controller="Admin" asp-action="DnevnikAktivnosti">
            Dnevnik aktivnosti
        </a>
    </li>
</ul>

<form asp-action="Index" method="get" class="mb-4">
    <div style="display:flex; gap:10px; max-width:500px;">

        <input type="text"
               name="pretraga"
               value="@ViewBag.Pretraga"
               class="form-control"
               placeholder="Pretraži korisnike..." />

        <button type="submit"
                style="
                    background:#ec6a7a;
                    color:white;
                    border:none;
                    border-radius:25px;
                    padding:10px 25px;
                    font-weight:600;
                    cursor:pointer;">
            Pretraži
        </button>

    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Ime</th>
            <th>Prezime</th>
            <th>Email</th>
            <th>Uloga</th>
            <th>Status</th>
            <th>Lokacija</th>
            <th>Pridružen</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var korisnik in Model)
        {
            <tr>
                <td>@korisnik.Ime</td>
                <td>@korisnik.Prezime</td>
                <td>@korisnik.Email</td>
                <td>@korisnik.Uloga</td>
                <td>@korisnik.StatusNaloga</td>

                <td>@korisnik.Grad, @korisnik.Regija</td>
                <td>-</td>

                <td>
                    <form asp-action="PromijeniStatus" asp-route-id="@korisnik.Id" method="post">
                        <button type="submit"
                                class="btn btn-sm @(korisnik.StatusNaloga == DigitalniKlubCitalaca.Models.StatusNaloga.aktivan ? "btn-danger" : "btn-success")">
                            @(korisnik.StatusNaloga == DigitalniKlubCitalaca.Models.StatusNaloga.aktivan ? "Suspenduj nalog" : "Aktiviraj nalog")
                        </button>
                    </form>
                    <form asp-action="PromijeniUlogu" asp-route-id="@korisnik.Id" method="post" class="mt-1">
                        <button type="submit" class="btn btn-sm btn-warning">
                            Promijeni ulogu
                        </button>
                    </form>
                </td>

            </tr>
        }
    </tbody>
</table>