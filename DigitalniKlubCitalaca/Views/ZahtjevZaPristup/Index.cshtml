@model IEnumerable<DigitalniKlubCitalaca.Models.ZahtjevZaPristup>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CitalackaGrupa)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumZahtjeva)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusZahtjeva)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Korisnik.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CitalackaGrupa.GrupaId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumZahtjeva)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusZahtjeva)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ZahtjevId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ZahtjevId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ZahtjevId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
